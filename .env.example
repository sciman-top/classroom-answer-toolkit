# Classroom Answer Toolkit AI gateway configuration template.
# Copy to .env for local use. Keep real keys out of version control.

# Cloud egress is disabled unless this is explicitly set to true.
CLASSROOM_TOOLKIT_CLOUD_EGRESS_ENABLED=false

# Primary OpenAI-compatible gateway for text planning and vision understanding.
CLASSROOM_TOOLKIT_AI_PRIMARY_KIND=openai_compatible
CLASSROOM_TOOLKIT_AI_PRIMARY_BASE_URL=https://primary.example.com/v1
CLASSROOM_TOOLKIT_AI_PRIMARY_API_KEY=
CLASSROOM_TOOLKIT_AI_PRIMARY_TEXT_MODEL=gpt-5.5
CLASSROOM_TOOLKIT_AI_PRIMARY_VISION_MODEL=gpt-5.5
CLASSROOM_TOOLKIT_AI_PRIMARY_TEXT_SURFACE=responses
CLASSROOM_TOOLKIT_AI_PRIMARY_VISION_SURFACE=responses

# Fallback OpenAI-compatible gateway.
CLASSROOM_TOOLKIT_AI_FALLBACK_1_KIND=openai_compatible
CLASSROOM_TOOLKIT_AI_FALLBACK_1_BASE_URL=https://fallback.example.com/v1
CLASSROOM_TOOLKIT_AI_FALLBACK_1_API_KEY=
CLASSROOM_TOOLKIT_AI_FALLBACK_1_TEXT_MODEL=gpt-5.5
CLASSROOM_TOOLKIT_AI_FALLBACK_1_VISION_MODEL=gpt-5.5
CLASSROOM_TOOLKIT_AI_FALLBACK_1_TEXT_SURFACE=responses
CLASSROOM_TOOLKIT_AI_FALLBACK_1_VISION_SURFACE=responses

# Optional image-generation lane. Keep separate from vision understanding.
CLASSROOM_TOOLKIT_IMAGE_PRIMARY_KIND=openai_compatible_image
CLASSROOM_TOOLKIT_IMAGE_PRIMARY_BASE_URL=https://primary.example.com/v1
CLASSROOM_TOOLKIT_IMAGE_PRIMARY_API_KEY=
CLASSROOM_TOOLKIT_IMAGE_PRIMARY_MODEL=gpt-image-2
CLASSROOM_TOOLKIT_IMAGE_PRIMARY_SURFACE=responses
CLASSROOM_TOOLKIT_IMAGE_PRIMARY_RESPONSES_MODEL=gpt-5.5
CLASSROOM_TOOLKIT_IMAGE_PRIMARY_TOTAL_CONCURRENCY=1

CLASSROOM_TOOLKIT_IMAGE_FALLBACK_1_KIND=openai_compatible_image
CLASSROOM_TOOLKIT_IMAGE_FALLBACK_1_BASE_URL=https://fallback.example.com/v1
CLASSROOM_TOOLKIT_IMAGE_FALLBACK_1_API_KEY=
CLASSROOM_TOOLKIT_IMAGE_FALLBACK_1_MODEL=gpt-image-2
CLASSROOM_TOOLKIT_IMAGE_FALLBACK_1_SURFACE=images
CLASSROOM_TOOLKIT_IMAGE_FALLBACK_1_TOTAL_CONCURRENCY=1
