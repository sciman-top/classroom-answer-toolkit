{
  "schemaVersion": "1.0",
  "assetId": "senior-physics-answer",
  "version": "v1.0-derived",
  "sourceOfTruth": {
    "humanSpec": "../specs/compiled/试卷参考答案交付规范-高中物理-完整版-v1.0.md",
    "mirroredSpec": "./spec.md",
    "acceptanceChecklist": "./checklists/acceptance.md"
  },
  "kind": "subject-pack-runtime-config",
  "inherits": [
    "../platform-core/manifest.json"
  ],
  "snapshot": {
    "cachePath": "../../.snapshot-cache/resolved-snapshot.senior-physics.json"
  },
  "deliveryRules": {
    "finalDeliverables": [
      ".md",
      ".pdf"
    ],
    "forbiddenFinalArtifacts": [
      ".txt",
      ".zip",
      "image-answer-pages",
      "review-page-images"
    ],
    "cleanupAfterSuccessfulDeliver": true
  },
  "formatRules": {
    "choiceAnswerLine": {
      "required": true,
      "formatExample": "1—5：A、B、C、D、A",
      "answersPerLine": 5,
      "compactLayoutRequired": true
    },
    "questionLead": {
      "firstSubQuestionSameLineRequired": true
    },
    "figureBinding": {
      "requireQuestionFigureBinding": true,
      "forbidCrossFigureAnswering": true
    },
    "nonChoiceAnswer": {
      "classroomDisplayDefault": true,
      "avoidLectureStyle": true,
      "preferSinglePageWithinReadability": true,
      "preferStepwiseFundamentalFormula": true,
      "preferMoreDirectEquivalentPath": true,
      "allowNecessaryDerivationForDifficultSubQuestion": true,
      "requireUnitSubstitution": true,
      "dropUnusedOriginalFormulaHintLine": true,
      "preferMovePrimaryUnknownBeforeWrap": true
    },
    "math": {
      "trueLatexRenderingRequired": true,
      "displayMathLeftAligned": true
    },
    "instrumentReading": {
      "preferOriginalImageReading": true,
      "calculationOnlyForCrossCheck": true,
      "requireFigureBindingBeforeReading": true,
      "requireSecondaryRangeAndScaleCheck": true,
      "requireAnchorChain": true,
      "requireNeighborMajorTickCrossCheck": true,
      "triggerRecheckOnScaleDivisionDisagreement": true,
      "coveredInstrumentTypes": [
        "ammeter",
        "voltmeter",
        "ruler",
        "thermometer",
        "spring-scale",
        "measuring-cylinder",
        "balance-rider"
      ]
    },
    "experimentDesign": {
      "scoreSentenceStyleRequired": true
    }
  },
  "profiles": {
    "default": "classroom",
    "classroom": {
      "plainTextCjkTarget": 20,
      "plainTextCjkMax": 24
    },
    "compact": {
      "plainTextCjkTarget": 24,
      "plainTextCjkMax": 30
    }
  },
  "evaluation": {
    "dataset": "../../eval/senior-physics-answer/dataset.json",
    "casesDir": "../../eval/senior-physics-answer/cases",
    "visualBaselinesDir": "../../eval/senior-physics-answer/baselines/visual"
  }
}
