{
  "schemaVersion": "1.0",
  "packId": "senior-physics-answer.figure-binding",
  "packVersion": "v8.11",
  "kind": "rule-pack",
  "metadata": {
    "subject": "senior-physics-answer",
    "priority": 92
  },
  "rules": [
    {
      "id": "senior-physics-answer.figure-binding.question-figure-map",
      "version": "1.0.0",
      "enabled": true,
      "severity": "hard",
      "priority": 92,
      "engine": "validate",
      "appliesTo": [
        "answer-md",
        "multi-figure-question"
      ],
      "params": {
        "requireQuestionFigureBinding": true,
        "forbidCrossFigureAnswering": true
      },
      "source": {
        "path": "./rules/figure-binding.json",
        "layer": "subject-pack"
      }
    }
  ]
}
