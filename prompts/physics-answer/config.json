{
  "schemaVersion": "1.0",
  "assetId": "physics-answer",
  "version": "v8.7-derived",
  "sourceOfTruth": {
    "humanSpec": "../../初中物理试卷参考答案生成与渲染交付提示词_v8.7_生产完整版.md",
    "mirroredSpec": "./spec.md",
    "acceptanceChecklist": "./checklists/acceptance.md"
  },
  "deliveryRules": {
    "finalDeliverables": [
      ".md",
      ".pdf"
    ],
    "forbiddenFinalArtifacts": [
      ".txt",
      ".zip",
      "image-answer-pages",
      "review-page-images"
    ],
    "cleanupAfterSuccessfulDeliver": true
  },
  "formatRules": {
    "choiceAnswerLine": {
      "required": true,
      "formatExample": "1—5：A、B、C、D、A",
      "answersPerLine": 5,
      "compactLayoutRequired": true
    },
    "questionLead": {
      "firstSubQuestionSameLineRequired": true
    },
    "nonChoiceAnswer": {
      "classroomDisplayDefault": true,
      "avoidLectureStyle": true,
      "preferSinglePageWithinReadability": true
    },
    "math": {
      "trueLatexRenderingRequired": true,
      "displayMathLeftAligned": true
    }
  },
  "profiles": {
    "default": "classroom",
    "classroom": {
      "plainTextCjkTarget": 20,
      "plainTextCjkMax": 24
    },
    "compact": {
      "plainTextCjkTarget": 24,
      "plainTextCjkMax": 30
    }
  },
  "evaluation": {
    "dataset": "../../eval/physics-answer/dataset.json",
    "casesDir": "../../eval/physics-answer/cases",
    "visualBaselinesDir": "../../eval/physics-answer/baselines/visual"
  }
}
