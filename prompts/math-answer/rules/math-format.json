{
  "schemaVersion": "1.0",
  "packId": "math-answer.math-format",
  "packVersion": "v0.1",
  "kind": "rule-pack",
  "metadata": {
    "subject": "math-answer",
    "priority": 80
  },
  "rules": [
    {
      "id": "math-answer.derivation.stepwise",
      "version": "1.0.0",
      "enabled": true,
      "severity": "soft",
      "priority": 80,
      "engine": "validate",
      "appliesTo": [
        "answer-md"
      ],
      "params": {
        "preferStepwiseDerivation": true,
        "allowEquivalentTransform": true
      },
      "source": {
        "path": "./rules/math-format.json",
        "layer": "subject-pack"
      }
    },
    {
      "id": "math-answer.probability.basic-notation",
      "version": "1.0.0",
      "enabled": true,
      "severity": "soft",
      "priority": 78,
      "engine": "validate",
      "appliesTo": [
        "answer-md"
      ],
      "params": {
        "preferStandardProbabilityNotation": true,
        "allowEventSymbolFractions": true,
        "restrictToTextGroundedCases": true
      },
      "source": {
        "path": "./rules/math-format.json",
        "layer": "subject-pack"
      }
    },
    {
      "id": "math-answer.statistics.basic-summary",
      "version": "1.0.0",
      "enabled": true,
      "severity": "soft",
      "priority": 77,
      "engine": "validate",
      "appliesTo": [
        "answer-md"
      ],
      "params": {
        "allowMeanMedianModeConclusion": true,
        "allowShortStatisticFormula": true,
        "restrictToTextGroundedCases": true
      },
      "source": {
        "path": "./rules/math-format.json",
        "layer": "subject-pack"
      }
    },
    {
      "id": "math-answer.function-graph.review-fallback",
      "version": "1.0.0",
      "enabled": true,
      "severity": "soft",
      "priority": 76,
      "engine": "validate",
      "appliesTo": [
        "answer-md"
      ],
      "params": {
        "allowReviewFallbackMarker": true,
        "markerPrefix": "【疑：",
        "restrictToGraphDependentCases": true
      },
      "source": {
        "path": "./rules/math-format.json",
        "layer": "subject-pack"
      }
    },
    {
      "id": "math-answer.geometry.review-fallback",
      "version": "1.0.0",
      "enabled": true,
      "severity": "soft",
      "priority": 75,
      "engine": "validate",
      "appliesTo": [
        "answer-md"
      ],
      "params": {
        "allowReviewFallbackMarker": true,
        "markerPrefix": "【疑：",
        "restrictToGeometryDependentCases": true
      },
      "source": {
        "path": "./rules/math-format.json",
        "layer": "subject-pack"
      }
    },
    {
      "id": "math-answer.chart-driven.review-fallback",
      "version": "1.0.0",
      "enabled": true,
      "severity": "soft",
      "priority": 74,
      "engine": "validate",
      "appliesTo": [
        "answer-md"
      ],
      "params": {
        "allowReviewFallbackMarker": true,
        "markerPrefix": "【疑：",
        "restrictToChartDrivenCases": true
      },
      "source": {
        "path": "./rules/math-format.json",
        "layer": "subject-pack"
      }
    }
  ]
}
