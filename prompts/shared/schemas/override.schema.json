{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://classroom-toolkit.dev/schemas/override/v1.json",
  "compatibility": {
    "forward": "additive",
    "backward": "additive"
  },
  "title": "Override",
  "type": "object",
  "required": [
    "overrideId",
    "baseSnapshot",
    "reason",
    "changes"
  ],
  "properties": {
    "overrideId": { "type": "string" },
    "baseSnapshot": { "type": "string" },
    "reason": { "type": "string" },
    "author": { "type": "string" },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
