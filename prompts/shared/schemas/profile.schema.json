{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://classroom-toolkit.dev/schemas/profile/v1.json",
  "compatibility": {
    "forward": "additive",
    "backward": "additive"
  },
  "title": "RenderProfile",
  "type": "object",
  "required": [
    "name"
  ],
  "properties": {
    "name": { "type": "string" },
    "inherits": {
      "type": "array",
      "items": { "type": "string" }
    },
    "layout": {
      "type": "object",
      "additionalProperties": true
    },
    "graphics": {
      "type": "object",
      "additionalProperties": true
    },
    "review": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
