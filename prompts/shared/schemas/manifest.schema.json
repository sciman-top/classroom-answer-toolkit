{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://classroom-toolkit.dev/schemas/manifest/v1.json",
  "compatibility": {
    "forward": "additive",
    "backward": "additive"
  },
  "title": "SubjectPackManifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "assetId",
    "displayName",
    "version",
    "status",
    "locale",
    "kind",
    "sourceOfTruth"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "assetId": { "type": "string" },
    "displayName": { "type": "string" },
    "version": { "type": "string" },
    "status": { "type": "string" },
    "locale": { "type": "string" },
    "domain": { "type": "string" },
    "kind": { "type": "string" },
    "inherits": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sourceOfTruth": {
      "type": "object",
      "additionalProperties": true
    },
    "entry": {
      "type": "object",
      "additionalProperties": true
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": true
    },
    "dataClassification": {
      "$ref": "./data-classification.schema.json"
    },
    "egressPolicy": {
      "type": "object",
      "required": [
        "allowCloud"
      ],
      "properties": {
        "allowCloud": { "type": "boolean" },
        "allowedProviders": {
          "type": "array",
          "items": { "type": "string" }
        },
        "redactBeforeEgress": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "tooling": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
