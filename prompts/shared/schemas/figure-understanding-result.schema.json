{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FigureUnderstandingResult",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "figureId",
    "baseFigureId",
    "anchors",
    "segments",
    "curves",
    "regions",
    "labels",
    "components",
    "confidence",
    "generatedAt"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": [
        "figure-understanding-result"
      ]
    },
    "figureId": { "type": "string" },
    "baseFigureId": { "type": "string" },
    "anchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "x",
          "y"
        ],
        "properties": {
          "id": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "label": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "from",
          "to"
        ],
        "properties": {
          "id": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "kind": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "curves": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "points"
        ],
        "properties": {
          "id": { "type": "string" },
          "points": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "x",
                "y"
              ],
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "regions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": { "type": "string" },
          "points": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "x",
                "y"
              ],
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text",
          "x",
          "y"
        ],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" }
        },
        "additionalProperties": true
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type"
        ],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "bbox": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "confidence": { "type": "number" },
    "generatedAt": { "type": "string" }
  },
  "additionalProperties": true
}
