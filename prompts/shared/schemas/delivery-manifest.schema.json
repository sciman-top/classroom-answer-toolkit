{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeliveryManifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "generatedAt",
    "subjectPack",
    "snapshotId",
    "snapshotPath",
    "snapshot",
    "profile",
    "input",
    "output",
    "review",
    "status"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": [
        "delivery-manifest"
      ]
    },
    "generatedAt": { "type": "string" },
    "subjectPack": { "type": "string" },
    "snapshotId": { "type": "string" },
    "snapshotPath": { "type": "string" },
    "snapshot": {
      "type": "object",
      "required": [
        "id",
        "version",
        "profile"
      ],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" },
        "profile": { "type": "string" }
      },
      "additionalProperties": true
    },
    "profile": { "type": "string" },
    "input": { "type": "string" },
    "output": { "type": "string" },
    "review": {
      "type": "object",
      "required": [
        "outputDir",
        "manifestPath",
        "scale"
      ],
      "properties": {
        "outputDir": { "type": "string" },
        "manifestPath": { "type": "string" },
        "scale": { "type": "string" }
      },
      "additionalProperties": true
    },
    "ocr": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": { "type": "string" },
        "provider": { "type": "string" },
        "version": { "type": "string" },
        "language": { "type": "string" },
        "pageCount": { "type": "number" },
        "error": { "type": "string" }
      },
      "additionalProperties": true
    },
    "graphics": {
      "type": "object",
      "required": [
        "items"
      ],
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "placementPath"
            ],
            "properties": {
              "placementPath": { "type": "string" },
              "previewPath": { "type": "string" },
              "placedGraphicId": { "type": "string" },
              "graphicId": { "type": "string" },
              "artifactId": { "type": "string" },
              "questionRef": { "type": "string" },
              "placementMode": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "status": {
      "type": "object",
      "required": [
        "toolchainPassed",
        "deliveryComplete",
        "reviewArtifactReady",
        "trusted"
      ],
      "properties": {
        "toolchainPassed": { "type": "boolean" },
        "deliveryComplete": { "type": "boolean" },
        "reviewArtifactReady": { "type": "boolean" },
        "visualReviewPassed": {
          "anyOf": [
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "trusted": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
