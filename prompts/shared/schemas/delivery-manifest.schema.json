{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeliveryManifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "generatedAt",
    "snapshotId",
    "snapshotPath",
    "snapshot",
    "profile",
    "input",
    "output",
    "review"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": [
        "delivery-manifest"
      ]
    },
    "generatedAt": { "type": "string" },
    "snapshotId": { "type": "string" },
    "snapshotPath": { "type": "string" },
    "snapshot": {
      "type": "object",
      "required": [
        "id",
        "version",
        "profile"
      ],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" },
        "profile": { "type": "string" }
      },
      "additionalProperties": true
    },
    "profile": { "type": "string" },
    "input": { "type": "string" },
    "output": { "type": "string" },
    "review": {
      "type": "object",
      "required": [
        "outputDir",
        "manifestPath",
        "scale"
      ],
      "properties": {
        "outputDir": { "type": "string" },
        "manifestPath": { "type": "string" },
        "scale": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
