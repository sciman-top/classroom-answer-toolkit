{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RulePack",
  "type": "object",
  "required": [
    "schemaVersion",
    "packId",
    "packVersion",
    "kind",
    "rules"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "packId": { "type": "string" },
    "packVersion": { "type": "string" },
    "kind": { "type": "string" },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "./rule.schema.json" }
    }
  },
  "additionalProperties": true
}
