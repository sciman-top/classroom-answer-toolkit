<Window x:Class="ClassroomToolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ClassroomToolkit"
        Width="1360"
        Height="860"
        Background="#08111F"
        Foreground="#E2E8F0"
        FontFamily="Microsoft YaHei UI"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.18,0.08" GradientOrigin="0.18,0.08" RadiusX="1.25" RadiusY="1.25">
                <GradientStop Color="#13213A" Offset="0" />
                <GradientStop Color="#08111F" Offset="0.56" />
                <GradientStop Color="#050B14" Offset="1" />
            </RadialGradientBrush>
        </Grid.Background>

        <Border Margin="24" Padding="24" Background="#0F172A" CornerRadius="24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1.55*" />
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="ClassroomToolkit" FontSize="34" FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="终态桌面壳层 · 本地规则快照 · 真实交付任务入口"
                                   Foreground="#94A3B8"
                                   FontSize="15" />

                        <Border Margin="0,22,0,0" Padding="16" Background="#111C31" CornerRadius="16">
                            <StackPanel>
                                <TextBlock Text="工作区" Foreground="#7DD3FC" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="{Binding RepositoryRoot}" TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0" Text="{Binding WorkspaceSummary}" Foreground="#CBD5E1" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,16,0,0" Padding="16" Background="#111C31" CornerRadius="16">
                            <StackPanel>
                                <TextBlock Text="工具链脚本" Foreground="#7DD3FC" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="{Binding BootstrapScriptPath}" TextWrapping="Wrap" FontSize="13" />
                                <TextBlock Margin="0,6,0,0" Text="{Binding CheckScriptPath}" TextWrapping="Wrap" FontSize="13" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,16,0,0" Padding="16" Background="#111C31" CornerRadius="16">
                            <StackPanel>
                                <TextBlock Text="交付任务" Foreground="#7DD3FC" FontWeight="SemiBold" />
                                <TextBlock Margin="0,10,0,0" Text="答案 Markdown" />
                                <TextBox Margin="0,6,0,0" Text="{Binding SelectedAnswerMarkdownPath, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,12,0,0" Text="输出 PDF" />
                                <TextBox Margin="0,6,0,0" Text="{Binding SelectedOutputPdfPath, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Margin="0,12,0,0" Text="Profile" />
                                <ComboBox Margin="0,6,0,0" SelectedValue="{Binding SelectedProfile}" SelectedValuePath="Tag">
                                    <ComboBoxItem Content="classroom" Tag="classroom" />
                                    <ComboBoxItem Content="compact" Tag="compact" />
                                </ComboBox>

                                <CheckBox Margin="0,12,0,0"
                                          IsChecked="{Binding KeepReviewArtifacts}"
                                          Content="保留 review 页图，便于人工复核" />

                                <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                                    <Button Content="选择答案 Markdown" Command="{Binding BrowseAnswerMarkdownCommand}" />
                                    <Button Content="执行答案交付" Command="{Binding DeliverCommand}" Background="#DC2626" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,16,0,0" Padding="16" Background="#111C31" CornerRadius="16">
                            <StackPanel>
                                <TextBlock Text="状态" Foreground="#7DD3FC" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="{Binding StatusMessage}" TextWrapping="Wrap" FontSize="14" />
                                <TextBlock Margin="0,6,0,0" Text="{Binding LastResultSummary}" Foreground="#94A3B8" TextWrapping="Wrap" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,16,0,0" Padding="16" Background="#111C31" CornerRadius="16">
                            <StackPanel>
                                <TextBlock Text="最近产物" Foreground="#7DD3FC" FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0" Text="{Binding LastOutputPdfPath}" TextWrapping="Wrap" FontSize="13" />
                                <TextBlock Margin="0,6,0,0" Text="{Binding LastDeliveryManifestPath}" TextWrapping="Wrap" FontSize="13" />
                                <TextBlock Margin="0,6,0,0" Text="{Binding LastReviewDirectoryPath}" TextWrapping="Wrap" FontSize="13" />
                                <TextBlock Margin="0,6,0,0" Text="{Binding LastSnapshotId}" TextWrapping="Wrap" FontSize="13" />
                                <TextBlock Margin="0,6,0,0" Text="{Binding LastDiagnosticsBundlePath}" TextWrapping="Wrap" FontSize="13" />
                                <TextBlock Margin="0,6,0,0" Text="{Binding LastDiagnosticsManifestPath}" TextWrapping="Wrap" FontSize="13" />
                                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                                    <Button Content="打开 PDF" Command="{Binding OpenLastOutputPdfCommand}" />
                                    <Button Content="打开 Manifest" Command="{Binding OpenLastDeliveryManifestCommand}" />
                                    <Button Content="打开 Review" Command="{Binding OpenLastReviewDirectoryCommand}" />
                                    <Button Content="导出诊断包" Command="{Binding ExportDiagnosticsCommand}" />
                                    <Button Content="打开诊断包" Command="{Binding OpenLastDiagnosticsBundleCommand}" />
                                    <Button Content="打开诊断清单" Command="{Binding OpenLastDiagnosticsManifestCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                            <Button Content="安装 / 修复工具链" Command="{Binding BootstrapCommand}" />
                            <Button Content="执行体检" Command="{Binding CheckCommand}" Background="#0EA5E9" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="1" Padding="16" Background="#0B1220" CornerRadius="18" BorderBrush="#1E293B" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="运行日志" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,12"
                                       Text="这里记录工具链安装、体检和答案交付的完整输出。"
                                       Foreground="#94A3B8"
                                       FontSize="12" />
                        </StackPanel>

                        <ItemsControl Grid.Row="1"
                                      Margin="0,0,0,12"
                                      ItemsSource="{Binding StatusCards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,12,0"
                                            Padding="12"
                                            CornerRadius="14"
                                            Background="#111827"
                                            BorderBrush="#1E293B"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" Foreground="#94A3B8" FontSize="12" />
                                            <TextBlock Margin="0,6,0,0" Text="{Binding Value}" FontSize="22" FontWeight="SemiBold" />
                                            <TextBlock Margin="0,6,0,0" Text="{Binding Detail}" Foreground="#CBD5E1" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl Grid.Row="2"
                                      Margin="0,0,0,12"
                                      ItemsSource="{Binding Issues}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            CornerRadius="10"
                                            Background="#2B1E1E">
                                        <TextBlock Text="{Binding}" Foreground="#FED7D7" TextWrapping="Wrap" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBox Grid.Row="3"
                                 Text="{Binding ActivityLog}"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 TextWrapping="Wrap"
                                 Background="#050B14"
                                 BorderBrush="#1E293B"
                                 FontFamily="Cascadia Mono" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
